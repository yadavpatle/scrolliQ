<?xml version="1.0" encoding="utf-8"?>
<!--
  "Cortex" — the ScrollIQ mascot, matching the in-app Flutter mascot
  (lib/shared/widgets/mascot.dart): a friendly lime brain-blob with dark ink
  eyes and a happy smile. Used in the floating HUD pill and the foreground
  notification. Kept as layered solid/gradient paths so it renders fast on the
  overlay layer of low-end devices.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="40dp"
    android:height="40dp"
    android:viewportWidth="48"
    android:viewportHeight="48">

    <!-- Body: rounded squircle with a vertical lime gradient -->
    <path
        android:pathData="M18,6 L30,6 Q43,6 43,19 L43,29 Q43,42 30,42 L18,42 Q5,42 5,29 L5,19 Q5,6 18,6 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="24" android:startY="5"
                android:endX="24" android:endY="43">
                <item android:offset="0.0" android:color="#FFD8FF82" />
                <item android:offset="1.0" android:color="#FFA6E046" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Definition outline -->
    <path
        android:pathData="M18,6 L30,6 Q43,6 43,19 L43,29 Q43,42 30,42 L18,42 Q5,42 5,29 L5,19 Q5,6 18,6 Z"
        android:strokeColor="#5C8A1F"
        android:strokeWidth="1.1"
        android:strokeAlpha="0.55"
        android:fillColor="#00000000" />

    <!-- Glossy top highlight -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.22"
        android:pathData="M20,15 m-9,0 a9,5 0 1,0 18,0 a9,5 0 1,0 -18,0 Z" />

    <!-- Faint brain folds (brain identity hint) -->
    <path
        android:strokeColor="#6FA12E"
        android:strokeWidth="1.1"
        android:strokeAlpha="0.45"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M16,12 Q18.5,15 16.5,18 M32,12 Q29.5,15 31.5,18 M24,10 L24,16" />

    <!-- Blush -->
    <path
        android:fillColor="#FF7A59"
        android:fillAlpha="0.34"
        android:pathData="M12.5,29 m-3.4,0 a3.4,2.3 0 1,0 6.8,0 a3.4,2.3 0 1,0 -6.8,0 Z" />
    <path
        android:fillColor="#FF7A59"
        android:fillAlpha="0.34"
        android:pathData="M35.5,29 m-3.4,0 a3.4,2.3 0 1,0 6.8,0 a3.4,2.3 0 1,0 -6.8,0 Z" />

    <!-- Eyes (dark ink) — big and round -->
    <path
        android:fillColor="#0A0B0E"
        android:pathData="M18,24 m-3.5,0 a3.5,3.5 0 1,0 7,0 a3.5,3.5 0 1,0 -7,0 Z" />
    <path
        android:fillColor="#0A0B0E"
        android:pathData="M30,24 m-3.5,0 a3.5,3.5 0 1,0 7,0 a3.5,3.5 0 1,0 -7,0 Z" />

    <!-- Big glossy catch-lights -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M16.6,22.5 m-1.4,0 a1.4,1.4 0 1,0 2.8,0 a1.4,1.4 0 1,0 -2.8,0 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M28.6,22.5 m-1.4,0 a1.4,1.4 0 1,0 2.8,0 a1.4,1.4 0 1,0 -2.8,0 Z" />
    <!-- Secondary sparkles -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.85"
        android:pathData="M19.3,25.4 m-0.7,0 a0.7,0.7 0 1,0 1.4,0 a0.7,0.7 0 1,0 -1.4,0 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.85"
        android:pathData="M31.3,25.4 m-0.7,0 a0.7,0.7 0 1,0 1.4,0 a0.7,0.7 0 1,0 -1.4,0 Z" />

    <!-- Small cute smile -->
    <path
        android:strokeColor="#0A0B0E"
        android:strokeWidth="2.2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M21,31 Q24,34 27,31" />
</vector>
