<?xml version="1.0" encoding="utf-8"?>
<!--
  Simplified brain-mascot vector. Hand-drawn paths kept light so the overlay
  layer renders fast even on low-end devices. Replace with a richer asset
  later if the design team supplies one (assets/images/brain_full.png).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="40dp"
    android:height="40dp"
    android:viewportWidth="40"
    android:viewportHeight="40">

    <!-- Pink head -->
    <path
        android:fillColor="#FF8FB7"
        android:pathData="M20,4 C12,4 6,9 6,16 C6,18 6.5,20 7.5,21.5
                         C6.5,22.5 6,24 6,25.5 C6,30 10,33 14,33
                         L26,33 C30,33 34,30 34,25.5
                         C34,24 33.5,22.5 32.5,21.5
                         C33.5,20 34,18 34,16 C34,9 28,4 20,4 Z" />

    <!-- Cerebrum fold lines -->
    <path
        android:strokeColor="#E15A85"
        android:strokeWidth="1.2"
        android:fillColor="#00000000"
        android:pathData="M20,6 L20,32 M13,8 C15,12 13,14 14,18
                         M27,8 C25,12 27,14 26,18" />

    <!-- Eyes -->
    <path
        android:fillColor="#1B1432"
        android:pathData="M15,18 m-2,0 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0 Z" />
    <path
        android:fillColor="#1B1432"
        android:pathData="M25,18 m-2,0 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0 Z" />

    <!-- Eye shine -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M14.4,17 m-0.6,0 a0.6,0.6 0 1,0 1.2,0 a0.6,0.6 0 1,0 -1.2,0 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M24.4,17 m-0.6,0 a0.6,0.6 0 1,0 1.2,0 a0.6,0.6 0 1,0 -1.2,0 Z" />

    <!-- Smile -->
    <path
        android:strokeColor="#1B1432"
        android:strokeWidth="1.2"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:pathData="M17,24 Q20,27 23,24" />
</vector>
