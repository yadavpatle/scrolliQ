<?xml version="1.0" encoding="utf-8"?>
<!--
  ScrollIQ launcher icon foreground — "Cortex", the lime brain mascot, matching
  the in-app Flutter mascot (lib/shared/widgets/mascot.dart).

  The artwork is authored on a 108x108 grid then wrapped in a <group> that
  scales it down to ~0.84 around the centre. Adaptive icons only guarantee the
  inner ~72dp is visible (the launcher mask clips the outer ring), so this keeps
  the whole mascot comfortably inside the safe zone — no clipped edges in the
  app drawer regardless of the device's icon mask (circle / squircle / rounded).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:name="mascot"
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="0.84"
        android:scaleY="0.84"
        android:translateY="1.5">

        <!-- Body: rounded squircle with a vertical lime gradient -->
        <path
            android:pathData="M43,20 L65,20 Q86,20 86,41 L86,63 Q86,84 65,84 L43,84 Q22,84 22,63 L22,41 Q22,20 43,20 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="54" android:startY="19"
                    android:endX="54" android:endY="85">
                    <item android:offset="0.0" android:color="#FFD8FF82" />
                    <item android:offset="1.0" android:color="#FFA6E046" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Definition outline -->
        <path
            android:pathData="M43,20 L65,20 Q86,20 86,41 L86,63 Q86,84 65,84 L43,84 Q22,84 22,63 L22,41 Q22,20 43,20 Z"
            android:strokeColor="#5C8A1F"
            android:strokeWidth="2"
            android:strokeAlpha="0.55"
            android:fillColor="#00000000" />

        <!-- Glossy top highlight -->
        <path
            android:fillColor="#FFFFFF"
            android:fillAlpha="0.22"
            android:pathData="M46,35 m-20,0 a20,11 0 1,0 40,0 a20,11 0 1,0 -40,0 Z" />

        <!-- Faint brain folds -->
        <path
            android:strokeColor="#6FA12E"
            android:strokeWidth="2"
            android:strokeAlpha="0.45"
            android:strokeLineCap="round"
            android:fillColor="#00000000"
            android:pathData="M37,28 Q42,35 38,42 M71,28 Q66,35 70,42 M54,24 L54,38" />

        <!-- Blush -->
        <path
            android:fillColor="#FF7A59"
            android:fillAlpha="0.32"
            android:pathData="M33,64 m-7.5,0 a7.5,5 0 1,0 15,0 a7.5,5 0 1,0 -15,0 Z" />
        <path
            android:fillColor="#FF7A59"
            android:fillAlpha="0.32"
            android:pathData="M75,64 m-7.5,0 a7.5,5 0 1,0 15,0 a7.5,5 0 1,0 -15,0 Z" />

        <!-- Eyes (dark ink) — big and round -->
        <path
            android:fillColor="#0A0B0E"
            android:pathData="M45,56 m-8,0 a8,8 0 1,0 16,0 a8,8 0 1,0 -16,0 Z" />
        <path
            android:fillColor="#0A0B0E"
            android:pathData="M63,56 m-8,0 a8,8 0 1,0 16,0 a8,8 0 1,0 -16,0 Z" />

        <!-- Big glossy catch-lights -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M42,52.5 m-3.4,0 a3.4,3.4 0 1,0 6.8,0 a3.4,3.4 0 1,0 -6.8,0 Z" />
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M60,52.5 m-3.4,0 a3.4,3.4 0 1,0 6.8,0 a3.4,3.4 0 1,0 -6.8,0 Z" />
        <!-- Secondary sparkles -->
        <path
            android:fillColor="#FFFFFF"
            android:fillAlpha="0.85"
            android:pathData="M48,59 m-1.6,0 a1.6,1.6 0 1,0 3.2,0 a1.6,1.6 0 1,0 -3.2,0 Z" />
        <path
            android:fillColor="#FFFFFF"
            android:fillAlpha="0.85"
            android:pathData="M66,59 m-1.6,0 a1.6,1.6 0 1,0 3.2,0 a1.6,1.6 0 1,0 -3.2,0 Z" />

        <!-- Small cute smile -->
        <path
            android:strokeColor="#0A0B0E"
            android:strokeWidth="3.2"
            android:strokeLineCap="round"
            android:fillColor="#00000000"
            android:pathData="M47,69 Q54,75 61,69" />
    </group>
</vector>
