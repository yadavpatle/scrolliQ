<?xml version="1.0" encoding="utf-8"?>
<!--
  Pill background for the reel-counter HUD bubble.
  Orange gradient mirrors the BRAINPAL palette while keeping ScrollIQ's amber
  accent. The shape is a horizontal pill so it can fit a brain icon + count.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="#FF8A3D"
        android:endColor="#E55C1F"
        android:angle="270" />
    <corners android:radius="48dp" />
    <stroke
        android:width="1dp"
        android:color="#33000000" />
</shape>
