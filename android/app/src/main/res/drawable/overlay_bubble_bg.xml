<?xml version="1.0" encoding="utf-8"?>
<!--
  Pill background for the reel-counter HUD bubble.
  Brand "warm-ink" glass pill so the lime Cortex mascot pops, with a subtle
  lime hairline matching the in-app theme (AppColors.primary).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="#F222632F"
        android:endColor="#F20B0C10"
        android:angle="270" />
    <corners android:radius="48dp" />
    <stroke
        android:width="1.5dp"
        android:color="#66C5F75A" />
</shape>
