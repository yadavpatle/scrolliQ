<?xml version="1.0" encoding="utf-8"?>
<!--
  Accessibility service config for ScrollIQ reel counter.

  We listen to vertical-scroll, window-state-change and window-content-change
  events. We must observe window-state-change events across apps (no
  packageNames whitelist) for one reason only: to know when the user LEAVES a
  short-video app, so the floating count pill can be hidden promptly. We never
  query or traverse the content of any non-whitelisted app — the service early-
  returns on a package check and only ever calls getRootInActiveWindow() / runs
  a detector for the four tracked short-video apps below. canRetrieveWindowContent
  is required so those per-app detectors can peek at view-id-resource-name nodes
  (e.g. clips_viewer_view_pager) to distinguish the reel feed from the rest of
  the app.

  Tracked apps (content inspected): com.instagram.android,
  com.google.android.youtube, com.facebook.katana, com.facebook.lite,
  com.snapchat.android.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeViewScrolled|typeWindowStateChanged|typeWindowContentChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagDefault|flagReportViewIds|flagRetrieveInteractiveWindows"
    android:canRetrieveWindowContent="true"
    android:notificationTimeout="100"
    android:description="@string/reel_counter_service_description" />
